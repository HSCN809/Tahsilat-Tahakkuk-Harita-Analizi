# =============================================================================
# Tahsilat Tahakkuk Harita Analizi — Production Ortam Degiskenleri
# =============================================================================
# Bu dosyayi .env.prod olarak kopyalayip degerleri doldurun:
#   cp .env.prod.example .env.prod
#
# Railway'de: Bu dosya OTOMATIK OKUNMAZ.
# Tum degiskenleri Railway Dashboard > Servis > Variables sekmesinden
# manuel olarak tanimlamaniz gerekir.
# =============================================================================

# --- Backend Servisi ---

# CORS: Virgulle ayrilmis izin verilen origin'ler.
# Production'da frontend'in gercek domain'ini yazin.
ALLOWED_ORIGINS=https://tahsilat.example.com

# /api/scrape endpoint'ini koruyan Bearer token.
# python -c "import secrets; print(secrets.token_urlsafe(32))" ile uretin.
# BU DEGISKEN ZORUNLUDUR — tanimlanmazsa /api/scrape 503 doner.
SCRAPE_TOKEN=change-me-to-a-secure-random-value

# Basarili scrape sonrasi snapshot yedeginin yazilacagi dizin.
# Railway'de /app mount path'i altinda bir dizin kullanin.
# Bos birakilirsa yedekleme devre disi kalir.
BACKUP_DIR=/app/backups

# Korunacak maksimum zaman damgali snapshot sayisi.
# Her scrape'de yeni bir timestamp'li snapshot olusur; bu sayi asilinca en eskiler silinir.
# En guncel snapshot her zaman "veriler-snapshot.tar.gz" olarak da saklanir.
SNAPSHOT_RETENTION=5

# Uvicorn worker sayisi. Railway 1 vCPU icin 1 onerilir.
WORKERS=1

# --- Scraper (yalnizca one-shot / manuel kullanim) ---

# One-shot scraper icin varsayilan yil araligi.
# docker compose ile manuel calistirmada kullanilir, Railway'de gecerli degildir.
# "hepsi" = tum yillar, "2024-2025" = belirli aralik.
SCRAPE_YEARS=hepsi

# --- Grafana (opsiyonel, yalnizca full docker compose stack) ---

# Grafana web arayuzu kullanici adi ve sifresi.
# GRAFANA_USER=admin
# GRAFANA_PASSWORD=change-me
